{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 5am on monday"],
  "prConcurrentLimit": 10,
  "platformAutomerge": true,
  "minimumReleaseAge": "3 days",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 5am on monday"]
  },
  "packageRules": [
    {
      "groupName": "compose",
      "matchPackageNames": ["androidx.compose{/,}**"]
    },
    {
      "groupName": "core",
      "matchPackageNames": ["androidx.core{/,}**"]
    },
    {
      "groupName": "lifecycle",
      "matchPackageNames": ["androidx.lifecycle{/,}**"]
    },
    {
      "groupName": "room",
      "matchPackageNames": ["androidx.room{/,}**"]
    },
    {
      "groupName": "hilt",
      "matchPackageNames": ["com.google.dagger{/,}**"]
    },
    {
      "groupName": "github-actions",
      "matchManagers": ["github-actions"],
      "prConcurrentLimit": 5
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    }
  ]
}
